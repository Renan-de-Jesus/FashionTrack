<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Images\fav.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="adicionar-usuario.png" />
    <None Remove="bolsa-de-compras.png" />
    <None Remove="caixa.png" />
    <None Remove="pontos-de-menu.png" />
    <None Remove="WhatsApp Image 2024-09-09 at 7.55.18 PM.jpeg" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="images\adicionar-usuario.png" />
    <Resource Include="images\bolsa-de-compras.png" />
